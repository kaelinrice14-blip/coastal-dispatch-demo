<%- include('../partials/header', { title, user }) %>

<div class="page-header">
  <div>
    <p class="breadcrumb">
      <a href="/employee">All Forms</a> /
      <a href="/employee/forms/<%= form.id %>">JSA</a>
    </p>
    <h1 class="page-title">JSA</h1>
    <p class="page-subtitle"><%= mode === 'new' ? 'Start New Form' : 'Edit Submission' %></p>
  </div>
</div>

<div class="card jsa-form-card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST"
        action="<%= mode === 'new' ? '/employee/forms/' + form.id + '/new' : '/employee/submissions/' + submission.id + '/edit' %>"
        id="jsa-form">

    <h2 class="jsa-form-title">JSA</h2>

    <h3 class="jsa-section-title">General Information</h3>

    <div class="form-group">
      <label for="job_site">Job Site / Wind Farm *</label>
      <select id="job_site" name="job_site" class="form-control" required>
        <option value="">— Select —</option>
        <% config.job_sites.forEach(function(site) { %>
          <option value="<%= site %>" <%= data.job_site === site ? 'selected' : '' %>><%= site %></option>
        <% }); %>
      </select>
    </div>

    <div class="form-group">
      <label>Date and Time *</label>
      <div class="datetime-wheel-group">
        <input type="date" id="date_time_date" class="form-control"
               value="<%= data.date_time ? data.date_time.split('T')[0] : '' %>" required>
        <%- include('../partials/time-wheel-picker', {
          id: 'date_time_time',
          name: 'date_time_time',
          value: data.date_time && data.date_time.includes('T') ? data.date_time.split('T')[1].slice(0,5) : '08:00',
          required: false
        }) %>
        <input type="hidden" name="date_time" id="date_time" class="datetime-combined"
               value="<%= data.date_time %>" required>
      </div>
    </div>

    <div class="form-group">
      <label for="customer">Customer *</label>
      <select id="customer" name="customer" class="form-control" required>
        <option value="">— Select —</option>
        <% config.customers.forEach(function(c) { %>
          <option value="<%= c %>" <%= data.customer === c ? 'selected' : '' %>><%= c %></option>
        <% }); %>
      </select>
    </div>

    <div class="form-group">
      <label for="tower_number">Tower Number</label>
      <input type="text" id="tower_number" name="tower_number" class="form-control"
             value="<%= data.tower_number %>">
    </div>

    <div class="form-group">
      <label for="site_contact">Site Contact</label>
      <input type="text" id="site_contact" name="site_contact" class="form-control"
             value="<%= data.site_contact %>">
    </div>

    <div class="form-group">
      <label for="site_contact_phone">Site Contact Phone Number</label>
      <input type="text" id="site_contact_phone" name="site_contact_phone" class="form-control"
             value="<%= data.site_contact_phone %>">
    </div>

    <div class="form-group">
      <label for="wind_weather_forecast">Wind/Weather Forecast</label>
      <input type="text" id="wind_weather_forecast" name="wind_weather_forecast" class="form-control"
             value="<%= data.wind_weather_forecast %>">
    </div>

    <div class="form-group">
      <label for="work_scope">Work Scope *</label>
      <textarea id="work_scope" name="work_scope" class="form-control jsa-work-scope" required
                placeholder="Describe the scope of work..."><%= data.work_scope %></textarea>
    </div>

    <div id="hazards-section">
      <div id="hazard-rows">
        <% data.hazards.forEach(function(hazard, index) { %>
          <div class="hazard-row" data-index="<%= index %>">
            <div class="form-group">
              <label>Potential Hazards *</label>
              <select name="hazard_potential_<%= index %>" class="form-control" required>
                <option value="">— Select —</option>
                <% config.potential_hazards.forEach(function(opt) { %>
                  <option value="<%= opt %>" <%= hazard.potential_hazard === opt ? 'selected' : '' %>><%= opt %></option>
                <% }); %>
              </select>
            </div>
            <div class="form-group">
              <label>Hazard Control Measures *</label>
              <select name="hazard_control_<%= index %>" class="form-control" required>
                <option value="">— Select —</option>
                <% config.hazard_control_measures.forEach(function(opt) { %>
                  <option value="<%= opt %>" <%= hazard.control_measure === opt ? 'selected' : '' %>><%= opt %></option>
                <% }); %>
              </select>
            </div>
            <% if (index > 0) { %>
              <button type="button" class="btn btn-outline btn-sm hazard-remove">Remove</button>
            <% } %>
          </div>
        <% }); %>
      </div>

      <button type="button" id="add-hazard-btn" class="btn btn-outline">Add Another Hazard</button>
    </div>

    <hr class="divider">

    <div class="form-group">
      <label for="customer_email">Customer Email *</label>
      <input type="email" id="customer_email" name="customer_email" class="form-control"
             value="<%= customerEmail %>" required>
      <p class="hint">Report will be emailed here when approved by your manager.</p>
    </div>

    <div style="display:flex;gap:12px;margin-top:8px">
      <button type="submit" class="btn btn-primary">
        <%= mode === 'new' ? 'Submit for Review' : 'Save & Resubmit' %>
      </button>
      <a href="/employee/forms/<%= form.id %>" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<script>
  window.JSA_CONFIG = <%- JSON.stringify(config) %>;
</script>
<script src="/js/time-wheel-picker.js"></script>
<script src="/js/jsa-hazards.js"></script>

<%- include('../partials/footer') %>