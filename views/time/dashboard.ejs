<%- include('../partials/header', { title, user }) %>

<div class="page-header">
  <div>
    <h1 class="page-title">Submit Time</h1>
    <p class="page-subtitle">Track and submit your work hours for manager approval</p>
  </div>
  <a href="/time/submit" class="btn btn-primary">+ New Time Entry</a>
</div>

<%- include('../partials/time-nav', { user, activeTab }) %>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type %>"><%= flash.message %></div>
<% } %>

<div class="time-stats-row">
  <div class="card stat-card">
    <span class="stat-label">This Week (Approved)</span>
    <span class="stat-value"><%= weekTotal.total_hours %>h</span>
    <span class="stat-sub"><%= weekTotal.entry_count %> entries · <%= weekTotal.week_start %> to <%= weekTotal.week_end %></span>
  </div>
  <% if (draftCount > 0) { %>
  <div class="card stat-card stat-warning">
    <span class="stat-label">Draft Entries</span>
    <span class="stat-value"><%= draftCount %></span>
    <a href="/time/submit" class="btn btn-primary btn-sm" style="margin-top:8px">Submit Now</a>
  </div>
  <% } %>
</div>

<div class="card table-wrap" style="margin-top:20px">
  <h2 class="list-heading">Recent Submissions</h2>
  <% if (recent.length === 0) { %>
    <div class="empty-state" style="padding:32px">
      <p>No time entries submitted yet.</p>
      <a href="/time/submit" class="btn btn-primary btn-sm">Submit Your First Entry</a>
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Hours</th>
          <th>Site</th>
          <th>Time</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% recent.forEach(function(e) { %>
        <tr>
          <td><%= e.entry_date %></td>
          <td><strong><%= e.total_hours %>h</strong></td>
          <td><%= e.site %></td>
          <td style="font-size:0.8125rem;color:var(--text-muted)"><%= e.start_time %> – <%= e.end_time %></td>
          <td><span class="badge badge-<%= e.status %>"><%= e.status %></span></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<%- include('../partials/footer') %>