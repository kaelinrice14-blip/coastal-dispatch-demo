<%- include('../partials/header', { title, user }) %>

<div class="page-header">
  <div>
    <p class="breadcrumb"><a href="/manager/forms">Manage Forms</a></p>
    <h1 class="page-title">Edit <%= form.name %> Form</h1>
    <p class="page-subtitle">Manage dropdown options — the form layout is fixed</p>
  </div>
</div>

<div class="card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/manager/forms/<%= form.id %>">
    <input type="hidden" name="bir_save" value="1">

    <h2 class="bir-form-title"><%= form.name %></h2>
    <p class="text-muted" style="margin-bottom:24px">Fixed layout. Edit manager-configurable dropdown options below.</p>

    <div class="form-row">
      <div class="form-group">
        <label for="customer_email_default">Default Customer Email</label>
        <input type="email" id="customer_email_default" name="customer_email_default" class="form-control"
               value="<%= form.customer_email_default || defaultCustomerEmail %>">
      </div>
      <div class="form-group">
        <label class="checkbox-label" style="margin-top:28px">
          <input type="checkbox" name="is_active" value="1" <%= form.is_active ? 'checked' : '' %>>
          Form is active (visible to employees)
        </label>
      </div>
    </div>

    <hr class="divider">

    <h3 class="bir-section-title">Dropdown Options</h3>
    <p class="text-muted" style="margin-bottom:20px">One option per line.</p>

    <div class="form-row">
      <div class="form-group">
        <label for="sites">Site Options</label>
        <textarea id="sites" name="sites" class="form-control option-list" rows="6"><%= config.sites.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="customers">Customer Options</label>
        <textarea id="customers" name="customers" class="form-control option-list" rows="6"><%= config.customers.join('\n') %></textarea>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="wtg_platforms">WTG Platform Options</label>
        <textarea id="wtg_platforms" name="wtg_platforms" class="form-control option-list" rows="6"><%= config.wtg_platforms.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="blade_oems">Blade OEM Options</label>
        <textarea id="blade_oems" name="blade_oems" class="form-control option-list" rows="6"><%= config.blade_oems.join('\n') %></textarea>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="blade_lengths">Blade Length Options</label>
        <textarea id="blade_lengths" name="blade_lengths" class="form-control option-list" rows="6"><%= config.blade_lengths.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="technicians">Coastal Composite Technician Options</label>
        <textarea id="technicians" name="technicians" class="form-control option-list" rows="6"><%= config.technicians.join('\n') %></textarea>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="damage_locations">Damage Location Options</label>
        <textarea id="damage_locations" name="damage_locations" class="form-control option-list" rows="6"><%= config.damage_locations.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="damage_descriptions">Damage Description Options</label>
        <textarea id="damage_descriptions" name="damage_descriptions" class="form-control option-list" rows="6"><%= config.damage_descriptions.join('\n') %></textarea>
      </div>
    </div>

    <div class="jsa-layout-preview">
      <h3 class="bir-section-title">Fixed Dropdowns (not editable)</h3>
      <ul class="layout-list">
        <li><strong>Blade Type:</strong> SST Structural, PPT Carbon Spar</li>
        <li><strong>Blade Designation:</strong> A, B, C, 1, 2, 3</li>
      </ul>

      <h3 class="bir-section-title" style="margin-top:20px">Form Layout (fixed)</h3>
      <ol class="layout-list">
        <li>Site, Customer, WTG Platform, WTG Local ID</li>
        <li>Blade OEM, Blade Type, Blade Length, Blade Designation</li>
        <li>Blade Serial Number, Damage ID</li>
        <li>Coastal Composite Technicians (2 default, add more)</li>
        <li>Inspection Date, Report Date</li>
        <li>Damage Location Radius, Damage Location, Damage Description</li>
        <li><strong>Damage Pictures</strong> — unlimited photos with optional descriptions</li>
      </ol>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn btn-primary">Save Options</button>
      <a href="/manager/forms" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>