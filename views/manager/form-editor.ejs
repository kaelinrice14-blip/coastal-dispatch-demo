<%- include('../partials/header', { title, user }) %>

<div class="page-header">
  <div>
    <p class="breadcrumb"><a href="/manager/forms">Manage Forms</a></p>
    <h1 class="page-title"><%= form && form.id ? 'Edit Form' : 'Create Form' %></h1>
    <p class="page-subtitle">Add any fields your team needs — text, dropdowns, photos, and more</p>
  </div>
</div>

<div class="card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form id="form-editor" method="POST" action="<%= form && form.id ? '/manager/forms/' + form.id : '/manager/forms' %>">
    <div class="form-row">
      <div class="form-group">
        <label for="name">Form Name *</label>
        <input type="text" id="name" name="name" class="form-control" required
               value="<%= form ? form.name : '' %>" placeholder="e.g. Site Inspection Report">
      </div>
      <div class="form-group">
        <label for="max_photos">Max Photos per Submission</label>
        <input type="number" id="max_photos" name="max_photos" class="form-control"
               min="0" max="50" value="<%= form ? form.max_photos : 5 %>">
        <p class="hint">Total photos allowed across all photo fields on this form.</p>
      </div>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" class="form-control" rows="2"
                placeholder="Brief description shown to employees"><%= form ? (form.description || '') : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="customer_email_default">Default Customer Email</label>
      <input type="email" id="customer_email_default" name="customer_email_default" class="form-control"
             value="<%= form ? (form.customer_email_default || '') : defaultCustomerEmail %>"
             placeholder="customer@example.com">
      <p class="hint">Pre-fills the customer email on submissions. Employees can override it.</p>
    </div>

    <% if (form && form.id) { %>
    <div class="form-group">
      <label class="checkbox-label">
        <input type="checkbox" name="is_active" value="1" <%= form.is_active ? 'checked' : '' %>>
        Form is active (visible to employees)
      </label>
    </div>
    <% } %>

    <hr class="divider">

    <div class="fields-header">
      <h2>Form Fields</h2>
      <button type="button" id="add-field-btn" class="btn btn-outline btn-sm">+ Add Field</button>
    </div>

    <div id="fields-container"></div>
    <input type="hidden" name="fields_json" id="fields_json">

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn btn-primary">Save Form</button>
      <a href="/manager/forms" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<script>
  window.FIELD_TYPES = <%- JSON.stringify(fieldTypes) %>;
  window.INITIAL_FIELDS = <%- JSON.stringify(fields) %>;
</script>
<script src="/js/form-builder.js"></script>

<%- include('../partials/footer') %>