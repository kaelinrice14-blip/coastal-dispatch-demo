<%- include('../partials/header', { title, user }) %>

<div class="page-header">
  <div>
    <p class="breadcrumb"><a href="/manager/forms">Manage Forms</a></p>
    <h1 class="page-title">Edit <%= form.name %> Form</h1>
    <p class="page-subtitle">Manage dropdown options — the form layout is fixed</p>
  </div>
</div>

<div class="card">
  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <form method="POST" action="/manager/forms/<%= form.id %>">
    <input type="hidden" name="brr_save" value="1">

    <h2 class="brr-form-title"><%= form.name %></h2>
    <p class="text-muted" style="margin-bottom:24px">Fixed multi-section repair workflow. Edit dropdown options below.</p>

    <div class="form-row">
      <div class="form-group">
        <label for="customer_email_default">Default Customer Email</label>
        <input type="email" id="customer_email_default" name="customer_email_default" class="form-control"
               value="<%= form.customer_email_default || defaultCustomerEmail %>">
      </div>
      <div class="form-group">
        <label class="checkbox-label" style="margin-top:28px">
          <input type="checkbox" name="is_active" value="1" <%= form.is_active ? 'checked' : '' %>>
          Form is active (visible to employees)
        </label>
      </div>
    </div>

    <hr class="divider">
    <h3 class="brr-section-title">Dropdown Options</h3>
    <p class="text-muted" style="margin-bottom:20px">One option per line.</p>

    <div class="form-row">
      <div class="form-group">
        <label for="customers">Customer Options</label>
        <textarea id="customers" name="customers" class="form-control option-list" rows="5"><%= config.customers.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="sites">Site Options</label>
        <textarea id="sites" name="sites" class="form-control option-list" rows="5"><%= config.sites.join('\n') %></textarea>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="wtg_platforms">WTG Platform Options</label>
        <textarea id="wtg_platforms" name="wtg_platforms" class="form-control option-list" rows="5"><%= config.wtg_platforms.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="blade_oems">Blade OEM Options</label>
        <textarea id="blade_oems" name="blade_oems" class="form-control option-list" rows="5"><%= config.blade_oems.join('\n') %></textarea>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="blade_types">Blade Type Options</label>
        <textarea id="blade_types" name="blade_types" class="form-control option-list" rows="5"><%= config.blade_types.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="blade_lengths">Blade Length Options</label>
        <textarea id="blade_lengths" name="blade_lengths" class="form-control option-list" rows="5"><%= config.blade_lengths.join('\n') %></textarea>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="technicians">Coastal Composite Technician Options</label>
        <textarea id="technicians" name="technicians" class="form-control option-list" rows="5"><%= config.technicians.join('\n') %></textarea>
      </div>
      <div class="form-group">
        <label for="materials_used">Material Used Options (Chemicals &amp; Lamination)</label>
        <textarea id="materials_used" name="materials_used" class="form-control option-list" rows="5"><%= config.materials_used.join('\n') %></textarea>
      </div>
    </div>

    <div class="jsa-layout-preview">
      <h3 class="brr-section-title">Fixed Options</h3>
      <p class="text-muted">Blade Designation: A, B, C, 1, 2, 3</p>
      <h3 class="brr-section-title" style="margin-top:16px">Sections with N/A toggle</h3>
      <p class="text-muted">Turbine Information, Chemicals Used, Initial Inspection, Topcoat Removed, Damage Exposed, Bonding Application, Lamination, Shore D Test, Filler Application, Paint</p>
    </div>

    <div style="display:flex;gap:12px;margin-top:24px">
      <button type="submit" class="btn btn-primary">Save Options</button>
      <a href="/manager/forms" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>